---
import Base from '../../../layouts/Base.astro';
import { t } from '../../../i18n/utils';
import { projects } from '../../../data/projects';

export function getStaticPaths() {
  return projects.map(p => ({ params: { slug: p.slug }, props: { project: p } }));
}

const { project: p } = Astro.props;
const lang = 'it';
---

<Base lang={lang} title={p.titleIt}>
  <div class="max-w-5xl mx-auto px-6 md:px-12 py-24">
    <!-- Back link -->
    <a href="/it/progetti" class="text-xs uppercase tracking-widest mb-8 inline-block" style="color: var(--color-primary);">
      {t(lang, 'projects.back')}
    </a>

    <!-- Header -->
    <p class="text-xs uppercase tracking-widest mb-3 mt-8" style="color: var(--color-primary);">{p.categoryIt}</p>
    <h1 class="section-title mb-2" style="color: var(--color-text);">{p.titleIt}</h1>
    <p class="text-sm mb-12" style="color: var(--color-accent);">{p.year} — {p.locationIt}</p>

    <!-- Description -->
    <p class="text-base leading-relaxed mb-6 max-w-3xl" style="color: var(--color-text);">{p.summaryIt}</p>
    <p class="text-sm leading-relaxed mb-6 max-w-3xl" style="color: var(--color-accent);">{p.descriptionIt}</p>

    <div class="grid grid-cols-2 gap-4 mb-12 max-w-lg">
      <div>
        <p class="text-xs uppercase tracking-widest mb-1" style="color: var(--color-primary);">Ruolo</p>
        <p class="text-sm" style="color: var(--color-text);">{p.roleIt}</p>
      </div>
      <div>
        <p class="text-xs uppercase tracking-widest mb-1" style="color: var(--color-primary);">Stato</p>
        <p class="text-sm" style="color: var(--color-text);">{p.statusIt}</p>
      </div>
    </div>

    {p.resultIt && (
      <div class="mb-12 p-4" style="background: var(--color-surface); border-left: 3px solid var(--color-primary);">
        <p class="text-xs uppercase tracking-widest mb-2" style="color: var(--color-primary);">Risultato</p>
        <p class="text-sm" style="color: var(--color-text);">{p.resultIt}</p>
      </div>
    )}

    <!-- Gallery -->
    <h2 class="text-xl font-heading font-bold mb-6" style="color: var(--color-text);">{t(lang, 'projects.gallery')}</h2>

    <div id="gallery" class="grid grid-cols-2 gap-3">
      {p.gallery.map((src, i) => (
        <button
          class="overflow-hidden focus:outline-none"
          style="aspect-ratio: 4/3;"
          onclick={`openLightbox(${i})`}
          data-gallery-index={i}
          type="button"
        >
          <img
            src={src}
            alt={`${p.titleIt} — foto ${i + 1}`}
            class="w-full h-full object-cover transition-all duration-300 hover:scale-105"
          />
        </button>
      ))}
    </div>
  </div>

  <!-- Lightbox overlay -->
  <div
    id="lightbox"
    class="fixed inset-0 z-50 hidden items-center justify-center"
    style="background: rgba(0,0,0,0.92);"
    onclick="closeLightbox(event)"
  >
    <button
      id="lb-prev"
      class="absolute left-4 top-1/2 -translate-y-1/2 text-4xl px-4 py-2 focus:outline-none"
      style="color: var(--color-text); background: none; border: none; cursor: pointer;"
      onclick="event.stopPropagation(); prevSlide()"
      type="button"
    >‹</button>

    <img id="lb-img" src="" alt="" class="max-h-screen max-w-full object-contain px-16" />

    <button
      id="lb-next"
      class="absolute right-4 top-1/2 -translate-y-1/2 text-4xl px-4 py-2 focus:outline-none"
      style="color: var(--color-text); background: none; border: none; cursor: pointer;"
      onclick="event.stopPropagation(); nextSlide()"
      type="button"
    >›</button>

    <button
      class="absolute top-4 right-6 text-3xl focus:outline-none"
      style="color: var(--color-text); background: none; border: none; cursor: pointer;"
      onclick="closeLightbox(event)"
      type="button"
    >×</button>
  </div>

  <script define:vars={{ gallery: p.gallery }}>
    let current = 0;

    function openLightbox(index) {
      current = index;
      document.getElementById('lb-img').src = gallery[current];
      const lb = document.getElementById('lightbox');
      lb.classList.remove('hidden');
      lb.classList.add('flex');
      document.body.style.overflow = 'hidden';
    }

    function closeLightbox(e) {
      if (e.target === document.getElementById('lightbox') || (e.currentTarget.tagName === 'BUTTON' && e.currentTarget !== document.getElementById('lb-prev') && e.currentTarget !== document.getElementById('lb-next'))) {
        document.getElementById('lightbox').classList.add('hidden');
        document.getElementById('lightbox').classList.remove('flex');
        document.body.style.overflow = '';
      }
    }

    function prevSlide() {
      current = (current - 1 + gallery.length) % gallery.length;
      document.getElementById('lb-img').src = gallery[current];
    }

    function nextSlide() {
      current = (current + 1) % gallery.length;
      document.getElementById('lb-img').src = gallery[current];
    }

    // Keyboard navigation
    document.addEventListener('keydown', (e) => {
      const lb = document.getElementById('lightbox');
      if (lb.classList.contains('hidden')) return;
      if (e.key === 'Escape') { lb.classList.add('hidden'); lb.classList.remove('flex'); document.body.style.overflow = ''; }
      if (e.key === 'ArrowLeft') prevSlide();
      if (e.key === 'ArrowRight') nextSlide();
    });
  </script>
</Base>
