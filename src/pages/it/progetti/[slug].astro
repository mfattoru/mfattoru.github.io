---
import Base from '../../../layouts/Base.astro';
import { t } from '../../../i18n/utils';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const entries = await getCollection('projects');
  return entries.map(entry => ({ params: { slug: entry.slug }, props: { project: entry.data } }));
}

const { project: p } = Astro.props;
const lang = 'it';
---

<Base lang={lang} title={p.titleIt}>
  <div class="max-w-5xl mx-auto px-6 md:px-12 py-24">
    <!-- Back link -->
    <a href="/it/progetti" class="text-xs uppercase tracking-widest mb-8 inline-block" style="color: var(--color-primary);">
      {t(lang, 'projects.back')}
    </a>

    <!-- Header -->
    <p class="text-xs uppercase tracking-widest mb-3 mt-8" style="color: var(--color-primary);">{p.categoryIt}</p>
    <h1 class="section-title mb-2" style="color: var(--color-text);">{p.titleIt}</h1>
    <p class="text-sm mb-12" style="color: var(--color-accent);">{p.year} — {p.locationIt}</p>

    <!-- Description -->
    <p class="text-base leading-relaxed mb-6 max-w-3xl" style="color: var(--color-text);">{p.summaryIt}</p>
    <p class="text-sm leading-relaxed mb-6 max-w-3xl" style="color: var(--color-accent);">{p.descriptionIt}</p>

    <div class="grid grid-cols-2 gap-4 mb-12 max-w-lg">
      <div>
        <p class="text-xs uppercase tracking-widest mb-1" style="color: var(--color-primary);">Ruolo</p>
        <p class="text-sm" style="color: var(--color-text);">{p.roleIt}</p>
      </div>
      <div>
        <p class="text-xs uppercase tracking-widest mb-1" style="color: var(--color-primary);">Stato</p>
        <p class="text-sm" style="color: var(--color-text);">{p.statusIt}</p>
      </div>
    </div>

    {p.resultIt && (
      <div class="mb-12 p-4" style="background: var(--color-surface); border-left: 3px solid var(--color-primary);">
        <p class="text-xs uppercase tracking-widest mb-2" style="color: var(--color-primary);">Risultato</p>
        <p class="text-sm" style="color: var(--color-text);">{p.resultIt}</p>
      </div>
    )}

    <!-- Carousel -->
    <h2 class="text-xl font-heading font-bold mb-6" style="color: var(--color-text);">{t(lang, 'projects.gallery')}</h2>

    <div class="relative" id="carousel">
      <!-- Main image -->
      <div class="overflow-hidden w-full" style="aspect-ratio: 16/9; background: var(--color-surface);">
        <img
          id="carousel-main"
          src={p.gallery[0]}
          alt={p.titleIt}
          class="w-full h-full object-cover"
        />
      </div>

      <!-- Prev / Next arrows -->
      <button
        id="carousel-prev"
        type="button"
        class="absolute left-3 top-1/2 -translate-y-1/2 flex items-center justify-center w-10 h-10 focus:outline-none"
        style="background: rgba(0,0,0,0.55); color: #fff; border: none; cursor: pointer; font-size: 1.5rem;"
        aria-label="Foto precedente"
      >‹</button>
      <button
        id="carousel-next"
        type="button"
        class="absolute right-3 top-1/2 -translate-y-1/2 flex items-center justify-center w-10 h-10 focus:outline-none"
        style="background: rgba(0,0,0,0.55); color: #fff; border: none; cursor: pointer; font-size: 1.5rem;"
        aria-label="Foto successiva"
      >›</button>

      <!-- Counter -->
      <div
        class="absolute bottom-3 right-4 text-xs px-2 py-1"
        id="carousel-counter"
        style="background: rgba(0,0,0,0.55); color: #fff;"
      >1 / {p.gallery.length}</div>
    </div>

    <!-- Thumbnail strip -->
    <div class="flex gap-2 mt-3 overflow-x-auto pb-2">
      {p.gallery.map((src, i) => (
        <button
          type="button"
          class="flex-shrink-0 focus:outline-none carousel-thumb"
          data-index={i}
          style={`width: 80px; height: 56px; border: 2px solid ${i === 0 ? 'var(--color-primary)' : 'transparent'};`}
        >
          <img src={src} alt={`Foto ${i + 1}`} class="w-full h-full object-cover" />
        </button>
      ))}
    </div>
  </div>

  <script define:vars={{ gallery: p.gallery }}>
    let current = 0;
    const main = document.getElementById('carousel-main');
    const counter = document.getElementById('carousel-counter');
    const thumbs = document.querySelectorAll('.carousel-thumb');

    function goTo(index) {
      current = (index + gallery.length) % gallery.length;
      main.src = gallery[current];
      counter.textContent = `${current + 1} / ${gallery.length}`;
      thumbs.forEach((t, i) => {
        t.style.borderColor = i === current ? 'var(--color-primary)' : 'transparent';
      });
    }

    document.getElementById('carousel-prev').addEventListener('click', () => goTo(current - 1));
    document.getElementById('carousel-next').addEventListener('click', () => goTo(current + 1));
    thumbs.forEach((thumb, i) => thumb.addEventListener('click', () => goTo(i)));

    document.addEventListener('keydown', (e) => {
      if (e.key === 'ArrowLeft') goTo(current - 1);
      if (e.key === 'ArrowRight') goTo(current + 1);
    });
  </script>
</Base>
