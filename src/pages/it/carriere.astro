---
import Base from '../../layouts/Base.astro';
import { t } from '../../i18n/utils';
const lang = 'it';
---
<Base lang={lang} title={t(lang, 'careers.title')}>
  <div class="max-w-4xl mx-auto px-6 md:px-12 py-24">
    <p class="section-subtitle">{t(lang, 'careers.subtitle')}</p>
    <h1 class="section-title mb-12" style="color: var(--color-text);">{t(lang, 'careers.title')}</h1>
    <div class="card p-8">
      <p class="text-sm leading-relaxed mb-4" style="color: var(--color-accent);">
        Al momento non abbiamo posizioni aperte, ma siamo sempre interessati a conoscere professionisti motivati nel campo dell'ingegneria e dell'edilizia.
      </p>
      <p class="text-sm leading-relaxed mb-8" style="color: var(--color-accent);">
        Se sei un ingegnere, geometra o tecnico con esperienza nel settore delle costruzioni, sicurezza o progettazione, invia la tua candidatura spontanea.
      </p>
      <a href={`mailto:${t(lang, 'contact.email.value')}?subject=Candidatura%20spontanea`} class="btn-outline">
        Invia candidatura spontanea
      </a>
    </div>
  </div>
</Base>
