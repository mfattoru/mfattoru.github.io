---
<!doctype html>
<html>
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Admin — Ing. Fattoruso</title>
  <link rel="cms-config-url" href="/it/admin/config.yml" />
  <script is:inline src="https://unpkg.com/decap-cms@^3.0.0/dist/decap-cms.js"></script>
</head>
<body>
  <script is:inline>
    // Auto-translate empty EN fields from IT using MyMemory (free, no key needed)
    async function translate(text) {
      if (!text || !text.trim()) return '';
      try {
        const res = await fetch(
          'https://api.mymemory.translated.net/get?q=' +
          encodeURIComponent(text) + '&langpair=it|en'
        );
        const data = await res.json();
        return data.responseData.translatedText || text;
      } catch {
        return text;
      }
    }

    const NEWS_FIELDS = [
      ['titleIt', 'titleEn'],
      ['descriptionIt', 'descriptionEn'],
      ['body', 'bodyEn'],
    ];
    const PROJECT_FIELDS = [
      ['titleIt', 'titleEn'],
      ['locationIt', 'locationEn'],
      ['roleIt', 'roleEn'],
      ['categoryIt', 'categoryEn'],
      ['summaryIt', 'summaryEn'],
      ['resultIt', 'resultEn'],
    ];

    const interval = setInterval(() => {
      if (typeof CMS !== 'undefined' && CMS.registerEventListener) {
        clearInterval(interval);
        CMS.registerEventListener({
          name: 'preSave',
          handler: async ({ entry }) => {
            const collection = entry.get('collection');
            const fields = collection === 'news' ? NEWS_FIELDS
                         : collection === 'projects' ? PROJECT_FIELDS
                         : null;
            if (!fields) return entry;

            let data = entry.get('data');
            for (const [itField, enField] of fields) {
              const itVal = data.get(itField);
              const enVal = data.get(enField);
              if (itVal && !enVal) {
                data = data.set(enField, await translate(itVal));
              }
            }
            return entry.set('data', data);
          },
        });
      }
    }, 200);
  </script>
</body>
</html>
