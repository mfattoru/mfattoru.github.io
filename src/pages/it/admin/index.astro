---
import { getCollection } from 'astro:content';
const settings = (await getCollection('site-settings'))[0]?.data;
const siteLanguage = settings?.siteLanguage ?? 'both';
const autoTranslateEnabled = siteLanguage === 'both';
---
<!doctype html>
<html lang="it">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Admin — Ing. Fattoruso</title>
  <script is:inline>
    if (!location.pathname.endsWith('/'))
      location.replace(location.pathname + '/' + location.search + location.hash);
  </script>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: system-ui, sans-serif;
      background: #0f172a;
      color: #f1f5f9;
      min-height: 100vh;
    }

    /* Loading screen */
    #cms-loading {
      position: fixed;
      inset: 0;
      background: #0f172a;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 1.5rem;
      z-index: 9999;
      transition: opacity 0.4s ease;
    }

    #cms-loading.fade-out {
      opacity: 0;
      pointer-events: none;
    }

    .loading-logo {
      font-size: 0.65rem;
      letter-spacing: 0.25em;
      text-transform: uppercase;
      color: #64748b;
    }

    .loading-title {
      font-size: 1.5rem;
      font-weight: 800;
      letter-spacing: 0.05em;
      text-transform: uppercase;
      color: #f1f5f9;
    }

    .loading-bar {
      width: 200px;
      height: 2px;
      background: #1e293b;
      border-radius: 2px;
      overflow: hidden;
    }

    .loading-bar-fill {
      height: 100%;
      width: 0%;
      background: #2563eb;
      animation: loadbar 1.8s ease forwards;
    }

    @keyframes loadbar {
      0%   { width: 0%; }
      60%  { width: 75%; }
      90%  { width: 92%; }
      100% { width: 100%; }
    }

    .loading-hint {
      font-size: 0.7rem;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: #334155;
    }

    /* Override Decap CMS chrome */
    #nc-root {
      font-family: system-ui, sans-serif !important;
    }

    #admin-tools {
      position: fixed;
      bottom: 1.25rem;
      right: 1.25rem;
      z-index: 2147483647;
      display: flex;
      gap: 0.5rem;
      opacity: 0;
      pointer-events: none;
      transition: opacity 0.3s ease;
    }

    #admin-tools.visible {
      opacity: 1;
      pointer-events: auto;
    }

    .admin-tool-link {
      display: inline-flex;
      align-items: center;
      gap: 0.35rem;
      padding: 0.4rem 0.8rem;
      background: #1e293b;
      color: #94a3b8;
      text-decoration: none;
      border-radius: 6px;
      font-size: 0.72rem;
      font-weight: 600;
      letter-spacing: 0.05em;
      text-transform: uppercase;
      border: 1px solid #334155;
      transition: background 0.15s, color 0.15s;
    }
    .admin-tool-link:hover {
      background: #273549;
      color: #f1f5f9;
    }
  </style>
</head>
<body>

  <div id="admin-tools">
    <a class="admin-tool-link" href="/it/admin/cache">🖼 Cache CDN</a>
  </div>

  <!-- Loading screen shown until CMS is ready -->
  <div id="cms-loading">
    <p class="loading-logo">Ing. Fattoruso Engineering Solutions</p>
    <p class="loading-title">Admin Panel</p>
    <div class="loading-bar"><div class="loading-bar-fill"></div></div>
    <p class="loading-hint">Caricamento in corso…</p>
  </div>

  <script is:inline src="https://unpkg.com/@sveltia/cms/dist/sveltia-cms.js"></script>

  <script is:inline>
    // ── Preview templates ──────────────────────────────────────────────────────
    // Registered once CMS is available. Each template renders the IT content
    // in a styled iframe that approximates the live site layout.
    const S = `
      body { font-family: 'Inter', system-ui, sans-serif; color: #1e293b; background: #fff; margin: 0; padding: 0; }
      .preview-wrap { max-width: 860px; margin: 0 auto; padding: 2rem 1.5rem 4rem; }
      .pre-title { font-size: .7rem; text-transform: uppercase; letter-spacing: .12em; color: #64748b; margin-bottom: .4rem; }
      h1 { font-family: 'Space Grotesk', system-ui, sans-serif; font-size: 2rem; font-weight: 800; margin: 0 0 .75rem; }
      h2 { font-size: 1.25rem; font-weight: 700; margin: 1.5rem 0 .5rem; }
      .desc { font-size: 1.05rem; color: #475569; margin-bottom: 2rem; }
      .hero { width: 100%; height: 280px; object-fit: cover; display: block; margin-bottom: 2rem; }
      .prose { font-size: .95rem; line-height: 1.75; color: #334155; }
      .meta-grid { display: grid; grid-template-columns: 1fr 1fr; gap: .75rem 1.5rem; margin-bottom: 1.5rem; }
      .meta-label { font-size: .65rem; text-transform: uppercase; letter-spacing: .1em; color: #2563eb; margin-bottom: .2rem; }
      .meta-value { font-size: .9rem; }
      .result-box { background: #f1f5f9; border-left: 3px solid #2563eb; padding: .75rem 1rem; margin-bottom: 1.5rem; font-size: .9rem; white-space: pre-line; }
      .badge { display: inline-block; background: #eff6ff; color: #2563eb; font-size: .7rem; font-weight: 600; text-transform: uppercase; letter-spacing: .08em; padding: .2rem .6rem; border-radius: 2px; margin-bottom: 1rem; }
    `;

    function waitCMS() {
      if (typeof CMS === 'undefined' || !CMS.registerPreviewStyle) {
        return setTimeout(waitCMS, 300);
      }

      const { h, createClass } = window.CMS.default || window.CMS;

      // ── News preview ──
      const NewsPreview = createClass({
        render() {
          const e = this.props.entry;
          const title = e.getIn(['data','titleIt']) || '';
          const desc   = e.getIn(['data','descriptionIt']) || '';
          const date   = e.getIn(['data','date']) || '';
          const image  = e.getIn(['data','image']) || '';
          const body   = this.props.widgetFor('body');
          const dateStr = date ? new Date(date).toLocaleDateString('it-IT',{year:'numeric',month:'long',day:'numeric'}) : '';
          return h('div', {className:'preview-wrap'},
            image && h('img', {src: image, className:'hero'}),
            dateStr && h('p', {className:'pre-title'}, dateStr),
            h('h1', {}, title),
            desc && h('p', {className:'desc'}, desc),
            h('div', {className:'prose'}, body)
          );
        }
      });

      // ── Projects preview ──
      const ProjectsPreview = createClass({
        render() {
          const e = this.props.entry;
          const p = (k) => e.getIn(['data', k]) || '';
          const body = this.props.widgetFor('body');
          return h('div', {className:'preview-wrap'},
            h('p', {className:'badge'}, p('categoryIt')),
            h('h1', {}, p('titleIt')),
            h('p', {className:'pre-title'}, `${p('year')} — ${p('locationIt')}`),
            h('p', {className:'prose', style:'margin-bottom:1.5rem; white-space:pre-line;'}, p('summaryIt')),
            h('div', {className:'meta-grid'},
              h('div', {}, h('p',{className:'meta-label'},'Ruolo'), h('p',{className:'meta-value'}, p('roleIt'))),
              h('div', {}, h('p',{className:'meta-label'},'Stato'), h('p',{className:'meta-value'}, p('statusIt')))
            ),
            p('resultIt') && h('div', {className:'result-box'},
              h('p', {className:'meta-label', style:'margin-bottom:.4rem;'},'Risultato'),
              p('resultIt')
            ),
            h('div', {className:'prose'}, body)
          );
        }
      });

      // ── Solutions preview ──
      const SolutionsPreview = createClass({
        render() {
          const e = this.props.entry;
          const title = e.getIn(['data','titleIt']) || '';
          const desc   = e.getIn(['data','descriptionIt']) || '';
          const image  = e.getIn(['data','image']) || '';
          const body   = this.props.widgetFor('body');
          return h('div', {className:'preview-wrap'},
            image && h('img', {src: image, className:'hero'}),
            h('h1', {}, title),
            desc && h('p', {className:'desc'}, desc),
            h('div', {className:'prose'}, body)
          );
        }
      });

      CMS.registerPreviewStyle('data:text/css,' + encodeURIComponent(S));
      CMS.registerPreviewTemplate('news', NewsPreview);
      CMS.registerPreviewTemplate('projects', ProjectsPreview);
      CMS.registerPreviewTemplate('solutions', SolutionsPreview);
    }

    waitCMS();
  </script>

  <script is:inline define:vars={{ autoTranslateEnabled }}>
    // ── Auto-translate empty EN fields from IT using MyMemory (free, no key) ──
    async function translate(text) {
      if (!text || !text.trim()) return '';
      try {
        const res = await fetch(
          'https://api.mymemory.translated.net/get?q=' +
          encodeURIComponent(text) + '&langpair=it|en'
        );
        const data = await res.json();
        return data.responseData.translatedText || text;
      } catch {
        return text;
      }
    }

    const NEWS_FIELDS = [
      ['titleIt', 'titleEn'],
      ['descriptionIt', 'descriptionEn'],
      ['body', 'bodyEn'],
    ];
    const PROJECT_FIELDS = [
      ['titleIt', 'titleEn'],
      ['locationIt', 'locationEn'],
      ['roleIt', 'roleEn'],
      ['categoryIt', 'categoryEn'],
      ['summaryIt', 'summaryEn'],
      ['resultIt', 'resultEn'],
    ];
    const SOLUTION_FIELDS = [
      ['titleIt', 'titleEn'],
      ['descriptionIt', 'descriptionEn'],
      ['body', 'bodyEn'],
    ];
    const PAGE_CONTENT_FIELDS = {
      about: [
        ['firmHeadingIt', 'firmHeadingEn'],
        ['firmBodyIt', 'firmBodyEn'],
        ['missionHeadingIt', 'missionHeadingEn'],
        ['missionBodyIt', 'missionBodyEn'],
      ],
      pricing: [
        ['introParagraphIt', 'introParagraphEn'],
        ['complianceParagraphIt', 'complianceParagraphEn'],
      ],
    };

    // Hide loading screen and register event listener once CMS global is ready
    const cmsInterval = setInterval(() => {
      if (typeof CMS !== 'undefined' && CMS.registerEventListener) {
        clearInterval(cmsInterval);

        const loader = document.getElementById('cms-loading');
        if (loader) {
          loader.classList.add('fade-out');
          setTimeout(() => loader.remove(), 450);
        }

        document.getElementById('admin-tools').classList.add('visible');

        CMS.registerEventListener({
          name: 'preSave',
          handler: async ({ entry }) => {
            if (!autoTranslateEnabled) return entry;
            const collection = entry.get('collection');
            let fields = collection === 'news' ? NEWS_FIELDS
                       : collection === 'projects' ? PROJECT_FIELDS
                       : collection === 'solutions' ? SOLUTION_FIELDS
                       : collection === 'page-content' ? PAGE_CONTENT_FIELDS[entry.get('slug')] ?? null
                       : null;
            if (!fields) return entry;

            let data = entry.get('data');
            for (const [itField, enField] of fields) {
              const itVal = data.get(itField);
              const enVal = data.get(enField);
              if (itVal && !enVal) {
                data = data.set(enField, await translate(itVal));
              }
            }
            return entry.set('data', data);
          },
        });
      }
    }, 200);
  </script>

</body>
</html>
