---
import Base from '../../../layouts/Base.astro';
import { t } from '../../../i18n/utils';
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';

const lang = 'it';
const solutions = (await getCollection('solutions')).sort((a, b) => a.data.order - b.data.order);
---
<Base lang={lang} title={t(lang, 'solutions.title')} description={t(lang, 'solutions.subtitle')}>
  <div class="max-w-6xl mx-auto px-6 md:px-12 py-24">
    <p class="section-subtitle">{t(lang, 'solutions.subtitle')}</p>
    <h1 class="section-title mb-16" style="color: var(--color-text);">{t(lang, 'solutions.title')}</h1>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {solutions.map((sol, i) => (
        <a href={`/it/soluzioni/${sol.slug}`} class="card block overflow-hidden transition-all hover:-translate-y-1">
          {sol.data.image && (
            <Image src={sol.data.image} alt={sol.data.titleIt} width={800} height={320} class="w-full h-40 object-cover object-top" loading={i < 3 ? 'eager' : 'lazy'} decoding="async" />
          )}
          <div class="p-8">
            {!sol.data.image && <div class="text-4xl mb-4">{sol.data.icon}</div>}
            <h2 class="font-heading font-bold text-xl mb-3" style="color: var(--color-text);">{sol.data.titleIt}</h2>
            <p class="text-sm mb-6" style="color: var(--color-accent);">{sol.data.descriptionIt}</p>
            <span class="text-xs uppercase tracking-widest" style="color: var(--color-primary);">{t(lang, 'solutions.view')}</span>
          </div>
        </a>
      ))}
    </div>
  </div>
</Base>
