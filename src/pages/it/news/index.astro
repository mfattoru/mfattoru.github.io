---
import Base from '../../../layouts/Base.astro';
import { t } from '../../../i18n/utils';
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';

const lang = 'it';
const posts = (await getCollection('news')).sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
---
<Base lang={lang} title={t(lang, 'news.title')}>
  <div class="max-w-4xl mx-auto px-6 md:px-12 py-24">
    <p class="section-subtitle">{t(lang, 'news.subtitle')}</p>
    <h1 class="section-title mb-12" style="color: var(--color-text);">{t(lang, 'news.title')}</h1>

    <div class="space-y-4">
      {posts.map((post, i) => (
        <a href={`/it/news/${post.slug}`} class="card block overflow-hidden transition-all hover:-translate-y-1">
          {post.data.image && (
            <Image src={post.data.image} alt={post.data.titleIt} width={800} height={320} class="w-full h-48 object-cover" loading={i === 0 ? 'eager' : 'lazy'} fetchpriority={i === 0 ? 'high' : 'auto'} decoding="async" />
          )}
          <div class="p-6">
            <p class="text-xs uppercase tracking-widest mb-2" style="color: var(--color-primary);">
              {new Date(post.data.date).toLocaleDateString('it-IT', { year: 'numeric', month: 'long', day: 'numeric' })}
            </p>
            <h2 class="font-heading font-bold text-lg mb-2" style="color: var(--color-text);">{post.data.titleIt}</h2>
            <p class="text-sm" style="color: var(--color-accent);">{post.data.descriptionIt}</p>
            <span class="inline-block mt-4 text-xs uppercase tracking-widest" style="color: var(--color-primary);">
              {t(lang, 'news.read.more')}
            </span>
          </div>
        </a>
      ))}
    </div>
  </div>
</Base>
