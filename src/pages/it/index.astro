---
import Base from '../../layouts/Base.astro';
import Hero from '../../components/Hero.astro';
import ServiceCard from '../../components/ServiceCard.astro';
import { t } from '../../i18n/utils';
import { getCollection, getEntry } from 'astro:content';
import { Image } from 'astro:assets';

const lang = 'it';
const solutions = (await getCollection('solutions')).sort((a, b) => a.data.order - b.data.order);
const recentProjects = (await getCollection('projects'))
  .sort((a, b) => b.data.year.localeCompare(a.data.year))
  .slice(0, 3);
const homepageContent = await getEntry('page-content', 'homepage');
const siteSettings = (await getCollection('site-settings'))[0]?.data;
const ctaBannerImage = siteSettings?.ctaBannerImage;
---

<Base lang={lang} title={t(lang, 'nav.home')}>
  <Hero
    title={t(lang, 'hero.title')}
    subtitle={t(lang, 'hero.subtitle')}
    ctaPrimary={{ label: t(lang, 'hero.cta.primary'), href: '/it/soluzioni' }}
    ctaSecondary={{ label: t(lang, 'hero.cta.secondary'), href: '/it/contatti' }}
  />

  <!-- Stats strip -->
  <section style="background: var(--color-surface); border-bottom: 1px solid var(--color-border);">
    <div class="max-w-6xl mx-auto px-6 md:px-12 py-12 grid grid-cols-2 md:grid-cols-4 gap-8 text-center">
      {[
        { value: homepageContent!.data.stat1Value, label: homepageContent!.data.stat1LabelIt },
        { value: homepageContent!.data.stat2Value, label: homepageContent!.data.stat2LabelIt },
        { value: homepageContent!.data.stat3Value, label: homepageContent!.data.stat3LabelIt },
        { value: homepageContent!.data.stat4Value, label: homepageContent!.data.stat4LabelIt },
      ].map(stat => (
        <div>
          <p class="text-4xl font-heading font-black mb-1" style="color: var(--color-primary);">{stat.value}</p>
          <p class="text-xs uppercase tracking-widest" style="color: var(--color-accent);">{stat.label}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- Services grid -->
  <section class="max-w-6xl mx-auto px-6 md:px-12 py-24">
    <p class="section-subtitle">{t(lang, 'home.services.subtitle')}</p>
    <h2 class="section-title" style="color: var(--color-text);">{t(lang, 'home.services.title')}</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 mt-12">
      {solutions.map(sol => (
        <ServiceCard
          title={sol.data.titleIt}
          description={sol.data.descriptionIt}
          icon={sol.data.icon}
          href={`/it/soluzioni/${sol.slug}`}
          linkLabel={t(lang, 'solutions.view')}
          image={sol.data.image}
        />
      ))}
    </div>
  </section>

  <!-- Recent projects -->
  {recentProjects.length > 0 && (
    <section class="py-24" style="background: var(--color-surface); border-top: 1px solid var(--color-border); border-bottom: 1px solid var(--color-border);">
      <div class="max-w-6xl mx-auto px-6 md:px-12">
        <p class="section-subtitle">{t(lang, 'projects.subtitle')}</p>
        <div class="flex items-end justify-between mb-12">
          <h2 class="section-title mb-0" style="color: var(--color-text);">{t(lang, 'home.projects.title')}</h2>
          <a href="/it/progetti" class="text-xs uppercase tracking-widest" style="color: var(--color-primary);">
            {t(lang, 'solutions.view')}
          </a>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          {recentProjects.map(entry => (
            <a href={`/it/progetti/${entry.slug}`} class="card overflow-hidden block transition-all hover:-translate-y-1">
              <Image src={entry.data.thumbnail} alt={entry.data.titleIt} width={800} height={384} class="w-full h-48 object-cover" loading="lazy" decoding="async" />
              <div class="p-6">
                <p class="text-xs uppercase tracking-widest mb-2" style="color: var(--color-accent);">{entry.data.year} — {entry.data.locationIt}</p>
                <p class="text-xs uppercase tracking-widest mb-3" style="color: var(--color-primary);">{entry.data.categoryIt}</p>
                <h3 class="font-heading font-bold text-sm" style="color: var(--color-text);">{entry.data.titleIt}</h3>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- CTA banner -->
  <section
    class="py-24 relative overflow-hidden"
    style={ctaBannerImage
      ? `background-image: url('${ctaBannerImage}'); background-size: cover; background-position: center;`
      : `background: var(--color-surface);`}
  >
    {ctaBannerImage && <div class="absolute inset-0" style="background: rgba(0,0,0,0.55);" />}
    <div class="relative max-w-6xl mx-auto px-6 md:px-12 text-center">
      <h2 class="section-title mb-4" style={ctaBannerImage ? 'color: #fff;' : 'color: var(--color-text);'}>{t(lang, 'home.cta.title')}</h2>
      <p class="mb-8" style={ctaBannerImage ? 'color: rgba(255,255,255,0.8);' : 'color: var(--color-accent);'}>{t(lang, 'home.cta.text')}</p>
      <a href="/it/preventivo" class="btn-primary">{t(lang, 'home.cta.button')}</a>
    </div>
  </section>
</Base>
