---
import Base from '../../layouts/Base.astro';
import { t } from '../../i18n/utils';
import { getCollection } from 'astro:content';

const lang = 'it';
const siteSettings = (await getCollection('site-settings'))[0]?.data;
const email = siteSettings?.email || t(lang, 'contact.email.value');
const phone = siteSettings?.phone || t(lang, 'contact.phone.value');
const phoneMobile = siteSettings?.phoneMobile || t(lang, 'contact.phone.mobile.value');
const address = siteSettings?.address || t(lang, 'contact.address');
const vatNumber = siteSettings?.vatNumber || '09348851214';
const FORMSPREE_ID = 'mlgobndz';

const services = [
  'Progettazione Architettonica',
  'Formazione Sicurezza',
  'Sicurezza Sul Lavoro',
  'Direzione Lavori e Coordinamento',
  'Superbonus 110%',
  'Sostenibilità ed Efficienza Energetica',
  'Acustica Edilizia ed Ambientale',
  'Estimo Immobiliare',
  'Edilizia',
];
---

<Base lang={lang} title={t(lang, 'contact.title')}>
  <div class="max-w-6xl mx-auto px-6 md:px-12 py-24 grid grid-cols-1 md:grid-cols-2 gap-16">
    <!-- Contact info column -->
    <div>
      <p class="section-subtitle">{t(lang, 'contact.subtitle')}</p>
      <h1 class="section-title mb-12" style="color: var(--color-text);">{t(lang, 'contact.title')}</h1>
      <ul class="space-y-8">
        <li>
          <p class="text-xs uppercase tracking-widest mb-1" style="color: var(--color-accent);">Indirizzo</p>
          <p style="color: var(--color-text);">{address}</p>
        </li>
        <li>
          <p class="text-xs uppercase tracking-widest mb-1" style="color: var(--color-accent);">Telefono</p>
          <a href={`tel:${phone}`} class="transition-colors hover:opacity-80" style="color: var(--color-primary);">
            {phone}
          </a>
          <br />
          <a href={`tel:${phoneMobile}`} class="transition-colors hover:opacity-80" style="color: var(--color-primary);">
            {phoneMobile}
          </a>
        </li>
        <li>
          <p class="text-xs uppercase tracking-widest mb-1" style="color: var(--color-accent);">Email</p>
          <a href={`mailto:${email}`} class="transition-colors hover:opacity-80" style="color: var(--color-primary);">
            {email}
          </a>
        </li>
        <li>
          <p class="text-xs uppercase tracking-widest mb-1" style="color: var(--color-accent);">Partita IVA</p>
          <p style="color: var(--color-text);">P.IVA: {vatNumber}</p>
        </li>
      </ul>
    </div>

    <!-- Form column -->
    <div>
      <form
        id="contact-form"
        action={`https://formspree.io/f/${FORMSPREE_ID}`}
        method="POST"
        class="space-y-6"
      >
        <div>
          <label for="c-name" class="block text-xs uppercase tracking-widest mb-2" style="color: var(--color-accent);">
            {t(lang, 'contact.name')} *
          </label>
          <input id="c-name" type="text" name="name" required class="w-full px-4 py-3 text-sm outline-none transition-colors focus:border-[var(--color-primary)]"
            style="background: var(--color-surface); border: 1px solid var(--color-border); color: var(--color-text);" />
        </div>
        <div>
          <label for="c-email" class="block text-xs uppercase tracking-widest mb-2" style="color: var(--color-accent);">
            {t(lang, 'contact.email')} *
          </label>
          <input id="c-email" type="email" name="email" required class="w-full px-4 py-3 text-sm outline-none"
            style="background: var(--color-surface); border: 1px solid var(--color-border); color: var(--color-text);" />
        </div>
        <div>
          <label for="c-phone" class="block text-xs uppercase tracking-widest mb-2" style="color: var(--color-accent);">
            {t(lang, 'contact.phone')}
          </label>
          <input id="c-phone" type="tel" name="phone" class="w-full px-4 py-3 text-sm outline-none"
            style="background: var(--color-surface); border: 1px solid var(--color-border); color: var(--color-text);" />
        </div>
        <div>
          <p class="block text-xs uppercase tracking-widest mb-3" style="color: var(--color-accent);">
            {t(lang, 'contact.service')}
          </p>
          <div class="space-y-2 px-4 py-3" style="background: var(--color-surface); border: 1px solid var(--color-border);">
            {services.map(s => (
              <label class="flex items-center gap-3 cursor-pointer group">
                <input type="checkbox" name="services" value={s}
                  class="w-4 h-4 shrink-0 accent-[var(--color-primary)]" />
                <span class="text-sm" style="color: var(--color-text);">{s}</span>
              </label>
            ))}
          </div>
        </div>
        <div>
          <label for="c-message" class="block text-xs uppercase tracking-widest mb-2" style="color: var(--color-accent);">
            {t(lang, 'contact.message')} *
          </label>
          <textarea id="c-message" name="message" required rows="5" class="w-full px-4 py-3 text-sm resize-none outline-none"
            style="background: var(--color-surface); border: 1px solid var(--color-border); color: var(--color-text);"></textarea>
        </div>
        <button type="submit" class="btn-primary w-full">{t(lang, 'contact.send')}</button>
        <p id="form-success" class="hidden text-sm text-center py-3" style="color: var(--color-primary);">
          {t(lang, 'contact.success')}
        </p>
        <p id="form-error" class="hidden text-sm text-center py-3 text-red-400">
          {t(lang, 'contact.error')}
        </p>
      </form>
    </div>
  </div>
</Base>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  const success = document.getElementById('form-success');
  const error = document.getElementById('form-error');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    try {
      const res = await fetch(form.action, {
        method: 'POST',
        body: new FormData(form),
        headers: { Accept: 'application/json' },
      });
      if (res.ok) {
        form.reset();
        success?.classList.remove('hidden');
        error?.classList.add('hidden');
      } else {
        error?.classList.remove('hidden');
        success?.classList.add('hidden');
      }
    } catch {
      error?.classList.remove('hidden');
      success?.classList.add('hidden');
    }
  });
</script>
