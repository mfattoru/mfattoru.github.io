---
import Base from '../../layouts/Base.astro';
import { t } from '../../i18n/utils';
import { projects } from '../../data/projects';
const lang = 'it';
---
<Base lang={lang} title={t(lang, 'projects.title')}>
  <div class="max-w-6xl mx-auto px-6 md:px-12 py-24">
    <p class="section-subtitle">{t(lang, 'projects.subtitle')}</p>
    <h1 class="section-title mb-12" style="color: var(--color-text);">{t(lang, 'projects.title')}</h1>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      {projects.map(p => (
        <a href={`/it/progetti/${p.slug}`} class="card overflow-hidden block transition-all hover:-translate-y-1">
          <img src={p.thumbnail} alt={p.titleIt} class="w-full h-48 object-cover" />
          <div class="p-6">
            <p class="text-xs uppercase tracking-widest mb-2" style="color: var(--color-accent);">{p.year} — {p.locationIt}</p>
            <p class="text-xs uppercase tracking-widest mb-3" style="color: var(--color-primary);">{p.categoryIt}</p>
            <h3 class="font-heading font-bold text-sm" style="color: var(--color-text);">{p.titleIt}</h3>
          </div>
        </a>
      ))}
    </div>
  </div>
</Base>
