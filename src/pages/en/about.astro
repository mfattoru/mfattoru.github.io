---
import Base from '../../layouts/Base.astro';
import { t } from '../../i18n/utils';
import { getCollection, getEntry } from 'astro:content';
import { Image } from 'astro:assets';
const lang = 'en';
const settings = await getCollection('site-settings');
const cvFile = settings[0]?.data.cvFile ?? '/Cv_ing_Onofrio_Fattoruso.pdf';
const aboutContent = await getEntry('page-content', 'about');
const homepageContent = await getEntry('page-content', 'homepage');
---
<Base lang={lang} title={t(lang, 'about.title')}>
  <div class="max-w-4xl mx-auto px-6 md:px-12 py-24">
    <p class="section-subtitle">{t(lang, 'about.subtitle')}</p>
    <h1 class="section-title mb-16" style="color: var(--color-text);">{t(lang, 'about.title')}</h1>

    <!-- Engineer photo + intro -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12 mb-16 items-start">
      <div class="md:col-span-1">
        <Image
          src="https://res.cloudinary.com/dd3aknabk/image/upload/f_auto,q_auto/site/headshot"
          alt="Ing. Onofrio Fattoruso"
          width={480} height={640}
          class="w-full object-cover"
          style="aspect-ratio: 3/4;"
          loading="eager"
          fetchpriority="high"
        />
      </div>
      <div class="md:col-span-2 grid grid-cols-1 gap-8">
        <div>
          <h2 class="text-xl font-heading font-bold mb-4" style="color: var(--color-text);">{aboutContent!.data.firmHeadingEn}</h2>
          <p class="text-sm leading-relaxed" style="color: var(--color-accent);">
            {aboutContent!.data.firmBodyEn}
          </p>
        </div>
        <div>
          <h2 class="text-xl font-heading font-bold mb-4" style="color: var(--color-text);">{aboutContent!.data.missionHeadingEn}</h2>
          <p class="text-sm leading-relaxed" style="color: var(--color-accent);">
            {aboutContent!.data.missionBodyEn}
          </p>
        </div>
      </div>
    </div>

    <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
      {[
        { value: homepageContent!.data.stat1Value, label: homepageContent!.data.stat1LabelEn },
        { value: homepageContent!.data.stat2Value, label: homepageContent!.data.stat2LabelEn },
        { value: homepageContent!.data.stat3Value, label: homepageContent!.data.stat3LabelEn },
        { value: homepageContent!.data.stat4Value, label: homepageContent!.data.stat4LabelEn },
      ].map(stat => (
        <div class="card p-6 text-center">
          <p class="text-3xl font-heading font-black mb-2" style="color: var(--color-primary);">{stat.value}</p>
          <p class="text-xs uppercase tracking-widest" style="color: var(--color-accent);">{stat.label}</p>
        </div>
      ))}
    </div>

    <!-- CV Preview + Download -->
    <div class="mt-16 pt-8" style="border-top: 1px solid var(--color-border);">
      <h2 class="text-xl font-heading font-bold mb-4" style="color: var(--color-text);">Curriculum Vitae</h2>

      <div class="mb-6 w-full overflow-hidden" style="border: 1px solid var(--color-border); height: 680px;">
        <iframe
          src={`${cvFile}#toolbar=0&navpanes=0`}
          title="Curriculum Vitae — Ing. Onofrio Fattoruso"
          class="w-full h-full"
          loading="lazy"
        >
          <p class="p-4 text-sm" style="color: var(--color-accent);">
            Your browser does not support PDF preview.
            <a href="/Cv_ing_Onofrio_Fattoruso.pdf" download style="color: var(--color-primary);">Download CV</a>
          </p>
        </iframe>
      </div>

    </div>
  </div>
</Base>
