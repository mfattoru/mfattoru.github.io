---
import { t } from '../i18n/utils';
import type { Lang } from '../i18n/utils';
import { getCollection } from 'astro:content';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const base = `/${lang}`;
const settings = (await getCollection('site-settings'))[0]?.data;
const email = settings?.email || t(lang, 'contact.email.value');
const phone = settings?.phone || t(lang, 'contact.phone.value');
const phoneMobile = settings?.phoneMobile || t(lang, 'contact.phone.mobile.value');
const address = settings?.address || t(lang, 'contact.address');
const vatNumber = settings?.vatNumber || '09348851214';
const hours = lang === 'it' ? (settings?.hoursIt || t(lang, 'contact.hours')) : (settings?.hoursEn || t(lang, 'contact.hours'));
const linkedinUrl = settings?.linkedinUrl || 'https://www.linkedin.com/in/onofriofattoruso/';

const solutionLinks = lang === 'it'
  ? [
      { href: `${base}/soluzioni/progettazione-architettonica`, label: t(lang, 'footer.solution.1') },
      { href: `${base}/soluzioni/sicurezza-sul-lavoro`, label: t(lang, 'footer.solution.2') },
      { href: `${base}/soluzioni/direzione-lavori`, label: t(lang, 'footer.solution.3') },
      { href: `${base}/soluzioni/superbonus-110`, label: t(lang, 'footer.solution.4') },
      { href: `${base}/soluzioni/sostenibilita-energetica`, label: t(lang, 'footer.solution.5') },
    ]
  : [
      { href: `${base}/solutions/architectural-design`, label: t(lang, 'footer.solution.1') },
      { href: `${base}/solutions/workplace-safety`, label: t(lang, 'footer.solution.2') },
      { href: `${base}/solutions/construction-management`, label: t(lang, 'footer.solution.3') },
      { href: `${base}/solutions/superbonus-110`, label: t(lang, 'footer.solution.4') },
      { href: `${base}/solutions/sustainability-energy`, label: t(lang, 'footer.solution.5') },
    ];
---

<footer class="mt-24" style="background: var(--color-surface); border-top: 1px solid var(--color-border);">
  <div class="max-w-6xl mx-auto px-6 md:px-12 py-16 grid grid-cols-1 md:grid-cols-3 gap-12">
    <!-- Brand -->
    <div>
      <p class="font-heading font-black text-lg uppercase tracking-widest mb-4" style="color: var(--color-text);">
        <span style="color: var(--color-primary);">ING.</span> FATTORUSO
      </p>
      <p class="text-sm leading-relaxed" style="color: var(--color-accent);">
        Engineering Solutions<br />
        {address}
      </p>
    </div>

    <!-- Services -->
    <div>
      <p class="text-xs font-bold uppercase tracking-widest mb-4" style="color: var(--color-text);">
        {t(lang, 'nav.solutions')}
      </p>
      <ul class="space-y-2">
        {solutionLinks.map(link => (
          <li>
            <a href={link.href} class="text-sm transition-colors hover:text-[var(--color-primary)]" style="color: var(--color-accent);">
              {link.label}
            </a>
          </li>
        ))}
      </ul>
    </div>

    <!-- Contact -->
    <div>
      <p class="text-xs font-bold uppercase tracking-widest mb-4" style="color: var(--color-text);">
        {t(lang, 'nav.contact')}
      </p>
      <ul class="space-y-2 text-sm" style="color: var(--color-accent);">
        <li>
          <a href={`mailto:${email}`} class="transition-colors hover:text-[var(--color-primary)]" style="color: var(--color-accent);">
            {email}
          </a>
        </li>
        <li>
          <a href={`tel:${phone}`} class="transition-colors hover:text-[var(--color-primary)]" style="color: var(--color-accent);">
            {phone}
          </a>
        </li>
        <li>
          <a href={`tel:${phoneMobile}`} class="transition-colors hover:text-[var(--color-primary)]" style="color: var(--color-accent);">
            {phoneMobile}
          </a>
        </li>
        <li>{lang === 'it' ? 'P.IVA: ' : 'VAT: '}{vatNumber}</li>
      </ul>
      <div class="mt-4 space-y-2 text-sm">
        <p style="color: var(--color-accent);">{hours}</p>
        {linkedinUrl && (
          <a href={linkedinUrl} target="_blank" rel="noopener" class="transition-colors hover:text-[var(--color-primary)]" style="color: var(--color-accent);">
            {t(lang, 'contact.linkedin')}
          </a>
        )}
      </div>
    </div>
  </div>

  <div
    class="border-t px-6 md:px-12 py-4 text-center text-xs"
    style="border-color: var(--color-border); color: var(--color-accent);"
  >
    © {new Date().getFullYear()} Ing. Onofrio Fattoruso — {t(lang, 'footer.rights')}
  </div>
</footer>
