---
import { getAlternateUrl } from '../i18n/utils';
import type { Lang } from '../i18n/utils';

interface Props {
  lang: Lang;
  currentUrl: URL;
}

const { lang, currentUrl } = Astro.props;
const alternateUrl = getAlternateUrl(currentUrl, lang === 'it' ? 'en' : 'it');
---

<div class="flex items-center gap-1 text-xs uppercase tracking-widest">
  {lang === 'it' ? (
    <span class="px-2 py-1 font-bold" style="color: var(--color-primary);">IT</span>
  ) : (
    <a href={alternateUrl} class="px-2 py-1 transition-colors" style="color: var(--color-accent);">IT</a>
  )}
  <span style="color: var(--color-border);">|</span>
  {lang === 'en' ? (
    <span class="px-2 py-1 font-bold" style="color: var(--color-primary);">EN</span>
  ) : (
    <a href={alternateUrl} class="px-2 py-1 transition-colors" style="color: var(--color-accent);">EN</a>
  )}
</div>
